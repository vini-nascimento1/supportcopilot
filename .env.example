SUPABASE_URL=https://sarbmqumaadpozmpenyr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://sarbmqumaadpozmpenyr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
INTERCOM_ACCESS_TOKEN=
INTERCOM_ADMIN_ID=
INTERCOM_APP_ID=
# Google OAuth — same client_id/secret configured in Supabase Auth → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Slack per-agent OAuth app
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Notion public OAuth integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Comma-separated list of manager emails who can see the Metrics tab
MANAGER_EMAILS=
# AI draft generation — Verboo router (OpenAI-compatible)
# Supports deepseek-chat, qwen-plus, and other models
VERBOO_API_KEY=
VERBOO_BASE_URL=https://code.verboo.ai/router/v1
# Optional overrides. Text drafts stay on DeepSeek by default; vision extraction uses Qwen.
VERBOO_TEXT_MODEL=deepseek-v4-flash
VERBOO_VISION_MODEL=qwen3.6-27b
VERBOO_DRAFT_TEMPERATURE=0.2

# Master key for encrypting per-agent personal AI keys at rest (Settings →
# Personal AI key). 32 bytes as hex (64 chars) or base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required before an agent can save a personal key; without it the feature is
# disabled (agents keep using the shared VERBOO_API_KEY above).
PROVIDER_ENCRYPTION_KEY=
